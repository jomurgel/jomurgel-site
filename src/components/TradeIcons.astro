---
// Decorative "tools of the trade" icons that slide in from the slab edges
// when a facet is hovered. Jo's own SVGs (src/icons/facets), imported raw —
// no runtime. One layer for the whole slab, groups keyed to each facet's ink:
//   c = Maker, m = Engineer/Architect, y = Artist, k = Photographer.
import maker1 from '../icons/facets/maker-1.svg?raw';
import maker2 from '../icons/facets/maker-2.svg?raw';
import maker3 from '../icons/facets/maker-3.svg?raw';
import maker4 from '../icons/facets/maker-4.svg?raw';
import dev1 from '../icons/facets/dev-1.svg?raw';
import dev2 from '../icons/facets/dev-2.svg?raw';
import dev3 from '../icons/facets/dev-3.svg?raw';
import dev4 from '../icons/facets/dev-4.svg?raw';
import art1 from '../icons/facets/art-1.svg?raw';
import art2 from '../icons/facets/art-2.svg?raw';
import art3 from '../icons/facets/art-3.svg?raw';
import art4 from '../icons/facets/art-4.svg?raw';
import photo1 from '../icons/facets/photo-1.svg?raw';
import photo2 from '../icons/facets/photo-2.svg?raw';
import photo3 from '../icons/facets/photo-3.svg?raw';
import photo4 from '../icons/facets/photo-4.svg?raw';

// Strip the XML prolog + DOCTYPE so only the <svg> is inlined into the page.
const clean = (svg) =>
  svg.replace(/<\?xml[\s\S]*?\?>\s*/i, '').replace(/<!DOCTYPE[\s\S]*?>\s*/i, '');

const icons = {
  maker1, maker2, maker3, maker4,
  dev1, dev2, dev3, dev4,
  art1, art2, art3, art4,
  photo1, photo2, photo3, photo4,
};

// [iconKey, position, slide-from, scale?] — each icon is sized from its OWN
// native viewBox (so line weights stay consistent across the set); the
// optional 4th value is a per-icon multiplier (default 1) for fine-tuning.
const groups = {
  c: [
    ['maker1', { left: '2%',  top: '15%' },    'left'],
    ['maker2', { right: '8%', top: '34%' },    'right'],
    ['maker3', { left: '16%', bottom: '6%' },  'bottom'],
    ['maker4', { right: '12%', bottom: '22%' }, 'bottom'],
  ],
  m: [
    ['dev1', { left: '6%',  top: '30%' },    'left'],
    ['dev2', { right: '3%', top: '15%' },    'right'],
    ['dev3', { left: '11%', bottom: '13%' }, 'bottom'],
    ['dev4', { right: '16%', bottom: '6%' },  'right'],
  ],
  y: [
    ['art1', { left: '3%',  top: '26%' },   'left'],
    ['art2', { right: '7%', top: '16%' },   'right'],
    ['art3', { left: '17%', bottom: '7%' }, 'bottom'],
    ['art4', { right: '11%', bottom: '24%' }, 'bottom'],
  ],
  k: [
    ['photo1', { left: '5%',  top: '17%' },    'left'],
    ['photo2', { right: '4%', top: '33%' },    'right'],
    ['photo3', { left: '12%', bottom: '15%' }, 'bottom'],
    ['photo4', { right: '15%', bottom: '6%' },  'bottom'],
  ],
};

// Pull width/height out of an SVG's viewBox ("minX minY W H").
const vbDims = (svg) => {
  const m = svg.match(/viewBox="\s*[\d.-]+\s+[\d.-]+\s+([\d.]+)\s+([\d.]+)/i);
  return m ? { w: +m[1], h: +m[2] } : { w: 100, h: 100 };
};

const fromVars = (dir) =>
  dir === 'left' ? '--fx:-200px;--fy:0px;'
  : dir === 'right' ? '--fx:200px;--fy:0px;'
  : '--fx:0px;--fy:180px;';

const posStyle = (p) => Object.entries(p).map(([k, v]) => `${k}:${v}`).join(';');
---

<div class="trade" aria-hidden="true">
  {Object.entries(groups).map(([ink, list]) => (
    <div class={`ig ig-${ink}`}>
      {list.map(([name, pos, dir, scale]) => {
        const svg = clean(icons[name]);
        const { w, h } = vbDims(svg);
        return (
          <span
            class="ficon"
            style={`${posStyle(pos)};${fromVars(dir)};--vbw:${w};--vbh:${h};${scale ? `--iscale:${scale};` : ''}`}
            set:html={svg}
          />
        );
      })}
    </div>
  ))}
</div>
