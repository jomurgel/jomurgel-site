---
// Base layout — wraps every page. Pulls in Acorn (content styling) and
// the site layer (layout), renders the shared header + footer.
import 'acorn.css';
import '../styles/site.css';
import { ClientRouter } from 'astro:transitions';
import signatureSvg from '../assets/signature.svg?raw';

const { title, description = "Jo Murgel — software architect and engineering lead. Trained as an artist.", heroInk, forceTheme, image, faceGone, noindex, schema } = Astro.props;
const pageTitle = title ? `${title} · Jo Murgel` : 'Jo Murgel';

// Absolute URLs for canonical + social cards (Astro.site = https://jomurgel.com).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image ?? '/og.png', Astro.site).href;

// Structured data: a sitewide Person + WebSite graph, plus any page-specific node
// (e.g. a BlogPosting on a post) passed in via the `schema` prop. Person is the
// @id everything references so crawlers tie it all to one identity.
const personId = new URL('#person', Astro.site).href;
const graph = [
  {
    '@type': 'Person',
    '@id': personId,
    name: 'Jo Murgel',
    url: Astro.site.href,
    image: new URL('/jo.jpg', Astro.site).href,
    jobTitle: 'Software architect and engineering lead',
    sameAs: [
      'https://github.com/jomurgel',
      'https://www.linkedin.com/in/jomurgel',
      'https://instagram.com/jomurgel',
    ],
  },
  {
    '@type': 'WebSite',
    '@id': new URL('#website', Astro.site).href,
    name: 'Jo Murgel',
    url: Astro.site.href,
    publisher: { '@id': personId },
  },
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
const jsonLd = { '@context': 'https://schema.org', '@graph': graph };

// Google Analytics 4. Put the real measurement ID here to switch it on; it
// only loads in production builds (never in dev), and stays off until set.
const GA_ID = 'G-JZ9V7XMT1E';
const analyticsOn = import.meta.env.PROD && /^G-[A-Z0-9]+$/.test(GA_ID) && !GA_ID.includes('XXX');

const nav = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/words', label: 'Words & Photos' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#e6177a" />
    <ClientRouter fallback="none" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Jo Murgel" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Jo Murgel — Words & Photos" href="/rss.xml" />

    <!-- Open Graph / social cards -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Jo Murgel" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <script is:inline define:vars={{ forceTheme }}>
      // Set theme before paint to avoid a flash. Photo posts force dark.
      const theme = forceTheme || localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
      // Content starts hidden (only when JS is on) so the entrance + scroll-reveal
      // animations can play — on first load and on every client-side navigation.
      document.documentElement.classList.add('entrance', 'reveal-on');
    </script>

    {analyticsOn && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          gtag('js', new Date());
          // Only count the live site, never local preview builds.
          if (location.hostname === 'jomurgel.com') gtag('config', GA_ID);
        </script>
      </>
    )}
  </head>
  <body class:list={[heroInk && 'has-hero']} data-force-theme={forceTheme}>
    <a href="#main" data-skip-link>Skip to content</a>

    <header class:list={['site-header', heroInk && 'site-header--overlay']} data-hero-ink={heroInk}>
      <a href="/" class="brand" aria-label="Jo Murgel — home">
        <span class="brand-word">jomurgel</span>
        <span class="brand-sig" aria-hidden="true" set:html={signatureSvg}></span>
      </a>
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
        <span class="nav-bars" aria-hidden="true"></span>
      </button>
      <nav id="site-nav" class="site-nav">
        <ul>
          {nav.map((item, i) => (
            <li style={`--i:${i}`}>
              <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="face-wrap">
        {faceGone ? (
          <div class="face-gone" role="img" aria-label="An empty, blurred dent where a little face used to be"></div>
        ) : (
        <button type="button" class="face-btn" title="Toggle theme" aria-label="Toggle light or dark theme">
        <svg class="face" viewBox="0 0 100 100" aria-hidden="true">
          <circle class="face-bg" cx="50" cy="50" r="46" />
          <circle class="crater" cx="29" cy="64" r="5" />
          <circle class="crater" cx="72" cy="55" r="3" />
          <circle class="crater" cx="58" cy="29" r="2.5" />
          <g class="features">
            <circle cx="38" cy="46" r="4" fill="#151513" />
            <circle cx="62" cy="46" r="4" fill="#151513" />
            <path class="mouth" d="M37 56 Q47.5 66 58 58 M58 54.5 L58 62.5" fill="none" stroke="#151513" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          </g>
        </svg>
        </button>
        )}
      </div>

      <nav aria-label="Elsewhere">
        <ul>
          <li><a href="https://darkfound.com">Darkfound</a></li>
          <li><a href="https://projectacorn.space">Project Acorn</a></li>
          <li><a href="https://thereforephotography.com">Therefore Photography</a></li>
          <li><a href="https://instagram.com/jomurgel">Instagram</a></li>
          <li><a href="https://github.com/jomurgel">GitHub</a></li>
          <li><a href="https://linkedin.com/in/jomurgel">LinkedIn</a></li>
        </ul>
      </nav>

      <p>
        Built with &hearts; by Jo Murgel on <a href="https://github.com/jomurgel/acorn.css">Acorn</a>. © 2026.
      </p>
    </footer>

    <script is:inline>
      (() => {
        // Globals — bound once; they survive client-side (ClientRouter) navigation.
        // (The mobile nav's Escape + focus trap are wired per-page below, in its toggle setup.)
        // Footer face follows the cursor (re-queries the live face each move).
        window.addEventListener('mousemove', (e) => {
          const face = document.querySelector('.face');
          const feat = face && face.querySelector('.features');
          if (!feat) return;
          const r = face.getBoundingClientRect();
          const cx = r.left + r.width / 2, cy = r.top + r.height / 2;
          const a = Math.atan2(e.clientY - cy, e.clientX - cx);
          const d = Math.min(5, Math.hypot(e.clientX - cx, e.clientY - cy) / 30);
          feat.setAttribute('transform', `translate(${Math.cos(a) * d} ${Math.sin(a) * d})`);
        }, { passive: true });

        // Per-page wiring — runs on first load and after every navigation.
        let first = true;
        document.addEventListener('astro:page-load', () => {
          // Mobile nav toggle — opens a full-screen overlay menu, managed as a dialog:
          // move focus in, trap it across the toggle + links, inert the rest, restore on close.
          const toggle = document.querySelector('.nav-toggle');
          const navEl = document.getElementById('site-nav');
          if (toggle && navEl) {
            let navInert = [];
            const navFocusables = () => [toggle, ...navEl.querySelectorAll('a[href]')];
            const onNavKey = (e) => {
              if (!navEl.isConnected) { document.removeEventListener('keydown', onNavKey, true); return; }
              if (toggle.getAttribute('aria-expanded') !== 'true') return;
              if (e.key === 'Escape') { e.preventDefault(); set(false); return; }
              if (e.key !== 'Tab') return;
              const f = navFocusables();
              const firstEl = f[0], lastEl = f[f.length - 1];
              if (e.shiftKey && document.activeElement === firstEl) { e.preventDefault(); lastEl.focus(); }
              else if (!e.shiftKey && document.activeElement === lastEl) { e.preventDefault(); firstEl.focus(); }
            };
            function set(open) {
              toggle.setAttribute('aria-expanded', String(open));
              toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
              navEl.classList.toggle('open', open);
              document.body.style.overflow = open ? 'hidden' : '';
              if (open) {
                const header = toggle.closest('header');
                navInert = [
                  document.getElementById('main'),
                  document.querySelector('footer'),
                  ...(header ? [...header.children].filter((el) => el !== toggle && el !== navEl) : []),
                ].filter(Boolean);
                navInert.forEach((el) => el.setAttribute('inert', ''));
                document.addEventListener('keydown', onNavKey, true);
                // The menu transitions visibility:hidden→visible; wait two frames so it's
                // actually focusable (one rAF still runs before that frame's style recalc).
                requestAnimationFrame(() => requestAnimationFrame(() => navEl.querySelector('a')?.focus()));
              } else {
                navInert.forEach((el) => el.removeAttribute('inert'));
                navInert = [];
                document.removeEventListener('keydown', onNavKey, true);
                toggle.focus();
              }
            }
            toggle.addEventListener('click', () => set(toggle.getAttribute('aria-expanded') !== 'true'));
            navEl.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => set(false)));
          }
          // Footer face: theme toggle.
          const btn = document.querySelector('.face-btn');
          if (btn) {
            const sync = () => btn.setAttribute('aria-pressed', String(document.documentElement.getAttribute('data-theme') === 'dark'));
            sync();
            btn.addEventListener('click', () => {
              const h = document.documentElement;
              const next = h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
              h.setAttribute('data-theme', next);
              localStorage.setItem('theme', next);
              sync();
            });
          }
          // Scroll reveal — runs on every page (initial load and each navigation).
          if (document.documentElement.classList.contains('reveal-on')
              && !matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
            const sel = 'main > section:not(.color-hero), main > article, main > header:not(.color-hero)';
            const io = new IntersectionObserver((entries, obs) => {
              entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-in'); obs.unobserve(e.target); } });
            }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
            document.querySelectorAll(sel).forEach((el) => io.observe(el));
          }
          // GA: send a page_view on client-side navigations (config sends the first).
          if (!first && window.gtag && location.hostname === 'jomurgel.com') {
            gtag('event', 'page_view', { page_path: location.pathname + location.search, page_title: document.title });
          }
          first = false;
        });

        // Runs after each navigation's DOM swap, before the new page paints. The swap
        // resets <html> to the server markup, dropping the runtime classes/attrs we set,
        // so re-apply all of them here (pre-paint, so the new page never flashes wrong).
        document.addEventListener('astro:after-swap', () => {
          const html = document.documentElement;
          // Theme (honors per-page forceTheme).
          const force = document.body.dataset.forceTheme;
          html.setAttribute('data-theme', force || localStorage.getItem('theme') || 'light');
          // Re-hide content so the scroll-reveal can play again on the new page.
          html.classList.add('reveal-on');
          // Restart the entrance keyframes (a swap doesn't replay them) — toggle + reflow.
          html.classList.remove('entrance');
          void html.offsetWidth;
          html.classList.add('entrance');
        });
      })();
    </script>
  </body>
</html>
