---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import PostList from '../../components/PostList.astro';
import Pagination from '../../components/Pagination.astro';
import TagBand from '../../components/TagBand.astro';
import { getCollection } from 'astro:content';
import { getAllTags } from '../../lib/words';

const PAGE_SIZE = 6;
const all = (await getCollection('words', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const posts = all.slice(0, PAGE_SIZE);
const totalPages = Math.ceil(all.length / PAGE_SIZE);
const tags = await getAllTags();
---

<Base title="Words & Photos" description="Writing and photography by Jo Murgel — dev notes, reflections, and art studies." heroInk="c">
  <PageHero
    ink="c"
    title="Words & Photos"
    lede="Dev notes, reflections, and photo studies — whatever I'm thinking about or shooting lately."
  />

  <section>
    <TagBand tags={tags} />
    <PostList posts={posts} />
    <Pagination currentPage={1} totalPages={totalPages} />
  </section>
</Base>
